{
  "application": "nzp-calculator",
  "version": "1.4.0",
  "sources": {
    "aggregation": {
      "name": "Справочник укрупнения",
      "url": "./aggregation-reference.xlsx",
      "format": "xlsx"
    }
  },
  "parsers": {
    "kfo": {
      "sheetAliases": ["КФО"],
      "headerSearchRows": 50,
      "updatedAtCell": "AN1",
      "fields": {
        "rowDate": { "aliases": ["Дата внесения РД", "Дата"], "required": false, "fallbackColumn": "B" },
        "markCode": { "aliases": ["Марка", "Марка код"], "required": false, "fallbackColumn": "J" },
        "erCode": { "aliases": ["Шифр ЕР", "Код ЕР"], "required": true, "fallbackColumn": "S" },
        "erName": { "aliases": ["Наименование ЕР"], "required": true, "fallbackColumn": "U" },
        "unit": { "aliases": ["Ед. Изм.", "Ед. изм.", "Ед. изм", "UoM"], "required": true, "fallbackColumn": "V" },
        "contractor": { "aliases": ["Подрядная организация", "Подрядчик", "Контрагент"], "required": true, "fallbackColumn": "AK" },
        "contractNumber": { "aliases": ["№ Договора подряда", "Номер договора подряда"], "required": false, "fallbackColumn": "AL" },
        "actualSmr": { "aliases": ["Факт СМР накопительно", "Факт СМР"], "required": true, "fallbackColumn": "AO" },
        "lastFactDate": { "aliases": ["Дата последнего факта СМР"], "required": false, "fallbackColumn": "AP" },
        "acceptedSk": { "aliases": ["Принято СК"], "required": true, "fallbackColumn": "AR" },
        "acceptedId": { "aliases": ["Принято ИД"], "required": true, "fallbackColumn": "AZ" },
        "kq1Code": { "aliases": ["KQ-1", "Код KQ-1"], "required": false, "fallbackColumn": "BI" },
        "kq1Coefficient": { "aliases": ["Коэф-1", "Коэф. KQ-1"], "required": false, "fallbackColumn": "BJ" },
        "kq2Code": { "aliases": ["KQ-2", "Код KQ-2"], "required": false, "fallbackColumn": "BK" },
        "kq2Coefficient": { "aliases": ["Коэф-2", "Коэф. KQ-2"], "required": false, "fallbackColumn": "BL" }
      },
      "recordRequiredFields": ["erCode", "unit", "contractor"]
    },
    "dk": {
      "sheetAliases": ["ДК"],
      "headerSearchRows": 30,
      "fields": {
        "markCode": { "aliases": ["Марка код", "Марка"], "required": true, "fallbackColumn": "A" },
        "contractor": { "aliases": ["Подрядная организация", "Подрядчик"], "required": false, "fallbackColumn": "B" },
        "contractNumber": { "aliases": ["№ Договора подряда", "Номер договора подряда"], "required": false, "fallbackColumn": "C" },
        "actualSmr": { "aliases": ["Факт СМР накопительно", "Факт СМР"], "required": true, "fallbackColumn": "E" },
        "acceptedSk": { "aliases": ["Принято СК"], "required": true, "fallbackColumn": "G" },
        "acceptedId": { "aliases": ["Архив ИД", "Принято ИД в архив"], "required": true, "fallbackColumn": "L" }
      }
    },
    "aggregation": {
      "headerSearchRows": 50,
      "fields": {
        "erCode": { "aliases": ["Шифр ЕР", "Код ЕР"], "required": true },
        "erName": { "aliases": ["Наименование ЕР"], "required": true },
        "unit": { "aliases": ["Ед. изм.", "Ед. изм", "UoM"], "required": true },
        "kq0Code": { "aliases": ["Код KQ-0"], "required": true },
        "kq0Name": { "aliases": ["Наименование KQ-0"], "required": true },
        "kq0Coefficient": { "aliases": ["Коэф. ФО KQ-0"], "required": true },
        "kq1Code": { "aliases": ["Код KQ-1"], "required": true },
        "kq1Name": { "aliases": ["Наименование KQ-1"], "required": true },
        "kq1Coefficient": { "aliases": ["Коэф. ФО KQ-1"], "required": true },
        "kq2Code": { "aliases": ["Код KQ-2"], "required": true },
        "kq2Name": { "aliases": ["Наименование KQ-2"], "required": true },
        "kq2Coefficient": { "aliases": ["Коэф. ФО KQ-2"], "required": true },
        "status": { "aliases": ["Статус"], "required": false }
      },
      "recordRequiredFields": ["erCode", "erName", "unit", "kq0Code", "kq1Code", "kq2Code"],
      "defaultStatus": "Действует"
    }
  },
  "kfoLogic": {
    "dateFilter": {
      "rowDateField": "rowDate",
      "lastFactDateField": "lastFactDate",
      "rowPolicy": "on-or-before",
      "futureFactPolicy": "zero"
    },
    "stages": [
      { "key": "actualSmr", "label": "Факт СМР накопительно", "regulationField": "actualSmr" },
      { "key": "acceptedSk", "label": "Принято СК", "regulationField": "acceptedSk" },
      { "key": "acceptedId", "label": "Принято ИД", "regulationField": "acceptedId" }
    ],
    "regulationMatchPriority": ["markCode+contractor+contractNumber", "markCode+contractor", "markCode"],
    "missingKq": "keep-er",
    "missingCoefficient": 1,
    "missingRegulationCoefficient": 1,
    "analysisOnlySheets": ["KQ"]
  },
  "aggregationLogic": {
    "matchField": "erCode",
    "activeLevel": "kq2",
    "displayHierarchy": ["kq1", "kq2", "er"],
    "quantityCalculation": {
      "operation": "multiply",
      "sourceField": "quantity",
      "rounding": 6
    },
    "levels": {
      "er": { "codeField": "erCode", "nameField": "erName", "coefficient": 1 },
      "kq2": { "codeField": "kq2Code", "nameField": "kq2Name", "coefficientField": "kq2Coefficient" },
      "kq1": { "codeField": "kq1Code", "nameField": "kq1Name", "coefficient": 1, "coefficientMode": "none" },
      "kq0": { "codeField": "kq0Code", "nameField": "kq0Name", "coefficient": 1, "coefficientMode": "none", "display": false }
    },
    "coefficientCorrections": {
      "byKq2Code": {},
      "byErCode": {}
    },
    "groupCorrections": {
      "kq1": {},
      "kq2": {}
    },
    "excludedStatuses": ["Аннулировано*"],
    "fallback": "keep-source"
  },
  "sourcePriority": [
    { "source": "kfo", "priority": 300 },
    { "source": "contractPrice", "priority": 200 },
    { "source": "aggregation", "priority": 100 }
  ]
}
