{
  "application": "nzp-calculator",
  "version": "1.1.0",
  "sources": {
    "aggregation": {
      "name": "Справочник укрупнения",
      "url": "./aggregation-reference.xlsx",
      "format": "xlsx"
    }
  },
  "parsers": {
    "aggregation": {
      "headerSearchRows": 50,
      "fields": {
        "erCode": { "aliases": ["Шифр ЕР", "Код ЕР"], "required": true },
        "erName": { "aliases": ["Наименование ЕР"], "required": true },
        "unit": { "aliases": ["Ед. изм.", "Ед. изм", "UoM"], "required": true },
        "kq0Code": { "aliases": ["Код KQ-0"], "required": true },
        "kq0Name": { "aliases": ["Наименование KQ-0"], "required": true },
        "kq0Coefficient": { "aliases": ["Коэф. ФО KQ-0"], "required": true },
        "kq1Code": { "aliases": ["Код KQ-1"], "required": true },
        "kq1Name": { "aliases": ["Наименование KQ-1"], "required": true },
        "kq1Coefficient": { "aliases": ["Коэф. ФО KQ-1"], "required": true },
        "kq2Code": { "aliases": ["Код KQ-2"], "required": true },
        "kq2Name": { "aliases": ["Наименование KQ-2"], "required": true },
        "kq2Coefficient": { "aliases": ["Коэф. ФО KQ-2"], "required": true },
        "status": { "aliases": ["Статус"], "required": false }
      },
      "recordRequiredFields": ["erCode", "erName", "unit", "kq0Code", "kq1Code", "kq2Code"],
      "defaultStatus": "Действует"
    }
  },
  "aggregationLogic": {
    "matchField": "erCode",
    "activeLevel": "kq2",
    "quantityCalculation": {
      "operation": "multiply",
      "sourceField": "quantity",
      "rounding": 6
    },
    "levels": {
      "er": { "codeField": "erCode", "nameField": "erName", "coefficient": 1 },
      "kq2": { "codeField": "kq2Code", "nameField": "kq2Name", "coefficientField": "kq2Coefficient" },
      "kq1": { "codeField": "kq1Code", "nameField": "kq1Name", "coefficientField": "kq1Coefficient" },
      "kq0": { "codeField": "kq0Code", "nameField": "kq0Name", "coefficientField": "kq0Coefficient" }
    },
    "excludedStatuses": ["Аннулировано*"],
    "fallback": "keep-source"
  },
  "sourcePriority": [
    { "source": "kfo", "priority": 300 },
    { "source": "contractPrice", "priority": 200 },
    { "source": "aggregation", "priority": 100 }
  ]
}
